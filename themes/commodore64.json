{
  "name": "Commodore 64",
  "id": "commodore64",
  "description": "Commodore 64 — light blue on deep blue, iconic 8-bit home computer",
  "author": "We Got Us Some Industries",
  "base": "terminal",
  "variables": {
    "accent":      "#c0c0ff",
    "accent-rgb":  "192, 192, 255",
    "accent-dim":  "#a0a0e8",
    "page-bg":     "#3535ce",
    "surface":     "#4040e0",
    "inner-bg":    "#2828b8",
    "danger":      "#ff5555",
    "text":        "#c0c0ff",
    "muted":       "rgba(192,192,255,0.55)",
    "border":      "rgba(192,192,255,0.35)",
    "font-body":   "'Courier New', monospace",
    "font-head":   "'Courier New', monospace",
    "scanlines":   "repeating-linear-gradient(0deg, rgba(192,192,255,0.04) 0px, transparent 1px, transparent 2px, rgba(192,192,255,0.04) 3px)",
